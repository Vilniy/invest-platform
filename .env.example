# ─────────────────────────────────────────────────────────
# Скопируй этот файл и переименуй в .env.local
# Заполни своими значениями из Supabase
# НИКОГДА не отправляй .env.local в GitHub!
# ─────────────────────────────────────────────────────────

# Supabase — берёшь из Settings → API в Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# База данных — берёшь из Settings → Database → Connection string
# Выбери "Transaction pooler" и скопируй URI
DATABASE_URL=

# Direct URL — тот же но порт 5432 (без pgbouncer)
DIRECT_URL=

# LiqPay — берёшь в личном кабинете на liqpay.ua
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# URL сайта (для callback после оплаты)
NEXT_PUBLIC_APP_URL=http://localhost:3000
